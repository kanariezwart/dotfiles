[user]
  name = Thijs Alberts

[include]
  path = ~/.gitconfig.local

[alias]
  discard    = reset --hard HEAD
  ch         = checkout
  sign       = commit -S -m
  signtag    = tag -s -m ""
  d          = diff
  graph      = log --graph
  last       = log -n 10
  whois      = "!sh -c 'git log -i -1 --pretty=\"format:%an <%ae>\n\" --author=\"$1\"' -"
  rmtag      = "!sh -c 'git tag -d $1; git push origin :refs/tags/$1'"

[commit]
  gpgsign = true

[core]
  editor     = nano
  autocrlf   = input
  pager      = delta

[credential]
  helper = osxkeychain

[gpg]
  program = gpg

[diff]
  colorMoved = zebra

[color "decorate"]
  HEAD                     = 14 normal italic
  remotebranch             = 13 normal
  grafted                  = 1 normal italic
  tag                      = 3 normal
  stash                    = 8 normal
  branch                   = 14 normal

[delta]
  syntax-theme = Solarized (dark)
  navigate = true
  line-numbers = true

[color "grep"]
  filename   = 7 normal
  function   = 10 normal
  column     = 8 normal
  linenumber = 8 normal

[interactive]
  diffFilter = delta --color-only

[color "interactive"]
  header     = 8 normal bold
  help       = 8 normal
  error      = 1 normal italic
  prompt     = 15 4

[color "status"]
  changed      = 11 normal
  unmerged     = 9 normal
  nobranch     = 1 normal italic
  updated      = 10 normal
  localbranch  = 14 normal
  added        = 10 normal
  untracked    = normal dim
  header       = normal
  remotebranch = 13 normal
  branch       = 14 normal

[color "branch"]
  remote   = 13 normal dim
  upstream = 13 normal
  plain    = 14 normal dim
  current  = 14 normal
  local    = 14 normal dim

[color "remote"]
  success = 2 normal
  error   = 1 normal
  hint    = normal dim
  warning = 3 normal
